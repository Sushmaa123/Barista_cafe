pipeline {
    agent { label 'ubuntu' }

    environment {
        // Git
        GIT_URL    = 'https://github.com/Sushmaa123/Barista_cafe.git'
        GIT_BRANCH = 'master'

        // Docker
        DOCKERHUB_REPO  = 'sushmaagowdaa/barista'
        IMAGE_TAG       = "${BUILD_NUMBER}"

        // Kubernetes
        APP_NAMESPACE   = 'default'
        DEPLOYMENT_NAME = 'barista'
        CONTAINER_NAME  = 'barista'

        // Reports
        IMG_REPORT  = 'trivy-image.html'
        TRIVY_IMAGE = 'aquasec/trivy:0.50.1'
    }

    stages {

        // 🔹 Checkout Code
        stage('Checkout') {
            steps {
                git branch: "${GIT_BRANCH}", url: "${GIT_URL}"
            }
        }

        // 🔹 Build Docker Image
        stage('Build Image') {
            steps {
                sh """
                docker build -t ${DOCKERHUB_REPO}:${IMAGE_TAG} .
                """
            }
        }

        // 🔹 Trivy Scan
        stage('Trivy Scan') {
            steps {
                sh """
                docker run --rm \
                  -v /var/run/docker.sock:/var/run/docker.sock \
                  -v \$(pwd):/workspace \
                  ${TRIVY_IMAGE} image \
                  --timeout 30m \
                  --format template \
                  --template "@/contrib/html.tpl" \
                  -o /workspace/${IMG_REPORT} \
                  ${DOCKERHUB_REPO}:${IMAGE_TAG}
                """
            }
        }

        // 🔹 Push to DockerHub
        stage('Docker Login & Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-cred',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                    echo \$DOCKER_PASS | docker login -u \$DOCKER_USER --password-stdin
                    docker push ${DOCKERHUB_REPO}:${IMAGE_TAG}
                    docker tag ${DOCKERHUB_REPO}:${IMAGE_TAG} ${DOCKERHUB_REPO}:latest
                    docker push ${DOCKERHUB_REPO}:latest
                    """
                }
            }
        }

        // 🔹 Deploy to Kubernetes
        stage('Deploy App (K8s)') {
            steps {
                sh """
                set -e

                echo "🔍 Checking cluster..."
                kubectl get nodes

                echo "📂 Checking files..."
                ls -l

                echo "🚀 Applying Kubernetes manifests..."
                kubectl apply -f deployment.yml
                kubectl apply -f service.yml
                kubectl apply -f hpa.yml
                kubectl apply -f ingress.yml

                echo "🔄 Updating image..."
                kubectl set image deployment/${DEPLOYMENT_NAME} \
                ${CONTAINER_NAME}=${DOCKERHUB_REPO}:${IMAGE_TAG} \
                -n ${APP_NAMESPACE}

                echo "⏳ Waiting for rollout..."
                kubectl rollout status deployment/${DEPLOYMENT_NAME} -n ${APP_NAMESPACE}
                """
            }
        }

        // 🔹 Verify Deployment
        stage('Verify Deployment') {
            steps {
                sh """
                echo "---- Pods ----"
                kubectl get pods -n ${APP_NAMESPACE}

                echo "---- Services ----"
                kubectl get svc -n ${APP_NAMESPACE}

                echo "---- HPA ----"
                kubectl get hpa -n ${APP_NAMESPACE}

                echo "---- Ingress ----"
                kubectl get ingress -n ${APP_NAMESPACE}
                """
            }
        }
    }

    post {

        success {
            echo "✅ Application deployed successfully with Ingress + HPA"
        }

        failure {
            echo "❌ Deployment failed → Rolling back"

            sh """
            kubectl rollout undo deployment/${DEPLOYMENT_NAME} -n ${APP_NAMESPACE} || true
            """
        }

        always {
            archiveArtifacts artifacts: "${IMG_REPORT}", allowEmptyArchive: false
            sh "docker logout || true"
        }
    }
}
