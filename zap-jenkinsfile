pipeline {
    agent { label 'ubuntu' }

    environment {
        ZAP_REPORT_PATH = 'Zap-Report.html'
        TARGET_URL = 'https://cloudops.live'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        stage('Run ZAP Scan') {
            steps {
                script {
                    echo "Starting OWASP ZAP Full Scan on ${TARGET_URL}"

                    def zapStatus = sh(
                        script: """
                        docker run --rm \
                          -u 0 \
                          -v \$(pwd):/zap/wrk/:rw \
                          ghcr.io/zaproxy/zaproxy:stable \
                          zap-full-scan.py \
                          -t ${TARGET_URL} \
                          -g gen.conf \
                          -r ${ZAP_REPORT_PATH}
                        """,
                        returnStatus: true
                    )

                    echo "ZAP Exit Code: ${zapStatus}"

                    if (zapStatus == 0) {
                        echo "✅ No vulnerabilities found"
                    } 
                    else if (zapStatus == 1 || zapStatus == 2) {
                        echo "⚠️ Security warnings found"
                        currentBuild.result = 'UNSTABLE'
                    } 
                    else {
                        error "❌ Critical vulnerabilities found! Failing pipeline"
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                if (fileExists("${ZAP_REPORT_PATH}")) {
                    echo "ZAP HTML report generated successfully: ${ZAP_REPORT_PATH}"
                } else {
                    echo "ZAP report not found, but continuing..."
                }
            }

            archiveArtifacts artifacts: "${ZAP_REPORT_PATH}", allowEmptyArchive: true
        }

        success {
            echo "✅ Build SUCCESS"
        }

        unstable {
            echo "⚠️ Build UNSTABLE (Security warnings)"
        }

        failure {
            echo "❌ Build FAILED (Critical vulnerabilities)"
        }
    }
}
